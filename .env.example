# Outbound SSO — devops-api's own client_credentials identity for calling ArgoCD's API
# (app/v1/argocd/conf.py's ARGOCD_SSO_* fields; see clusters-provision/clusters/rhbk's
# argocdServiceClient for the Keycloak side). Leave ARGOCD_SSO_CLIENT_SECRET empty for local
# dev against docker-compose ArgoCD with no real Keycloak — cluster-secret routes will fail
# at the auth step, same as any other tool needing real platform credentials locally.
ARGOCD_SSO_TOKEN_URL=https://rhbk.devopstashtiot.page/realms/devtools/protocol/openid-connect/token
ARGOCD_SSO_CLIENT_ID=devops-api-argocd
ARGOCD_SSO_CLIENT_SECRET=
ARGOCD_SSO_SCOPE=devops-api-argocd-audience
CLUSTERS=["dev","rak"]
